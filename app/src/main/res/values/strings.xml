    <!-- Economy server commands -->
    <string name="server_econ_cmd_1">/bal - Check your balance</string>
    <string name="server_econ_cmd_2">/pay &lt;player&gt; &lt;amount&gt; - Pay someone</string>
    <string name="server_econ_cmd_3">/baltop - Top balances</string>
    <string name="server_econ_cmd_4">/shop - Buy or Sell Items</string>

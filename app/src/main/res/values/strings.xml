    <!-- Basic server commands -->
    <string name="server_basic_cmd_1">/spawn - Teleport to spawn</string>
    <string name="server_basic_cmd_2">/rtp - Telport to a random location</string>
    <string name="server_basic_cmd_3">/home - Teleport to your home if you have one</string>
    <string name="server_basic_cmd_4">/sethome - Set your home location</string>
    <string name="server_basic_cmd_5">/warp &lt;name&gt; - Teleport to warp</string>
    <string name="server_basic_cmd_6">/pwarp &lt;name&gt; - Teleport to a players warp</string>
    <string name="server_basic_cmd_7">/pvp - Activate/Deactivate PVP</string>
    <string name="server_basic_cmd_8">/tpask &lt;player&gt; - Send teleport request</string>
    <string name="server_basic_cmd_9">/tpaccept - Accept teleport request</string>
    <string name="server_basic_cmd_10">/tpadeny - Deny teleport request</string>
    <string name="server_basic_cmd_11">/msg &lt;player&gt; &lt;message&gt; - Talk to a Player Privately</string>
    <string name="server_basic_cmd_12">/warp center - Go to Welcome Center</string>
    <string name="server_basic_cmd_13">/kiss &lt;player&gt; - Kiss a player</string>
    <string name="server_basic_cmd_14">/warp arena - Teleport to Arena for fighting against other Players</string>
    <string name="server_basic_cmd_15">/fly - Activate/Deactivate flying</string>
    <string name="server_basic_cmd_16">/trash - Dispose of useless items</string>
    <string name="server_basic_cmd_17">/wb - Welcome a Player back</string>
    <string name="server_basic_cmd_18">/warp crates - Open crates when you get keys</string>

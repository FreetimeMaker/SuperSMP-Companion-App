    <!-- Land claim commands -->
    <string name="server_land_cmd_1">/claim - Claim current chunk</string>
    <string name="server_land_cmd_2">/unclaim - Unclaim current chunk</string>
    <string name="server_land_cmd_3">/claims - List your claims</string>
    <string name="server_land_cmd_4">/trust &lt;player&gt; - Trust player</string>
    <string name="server_land_cmd_5">/untrust &lt;player&gt; - Untrust player</string>
    <string name="server_land_cmd_6">/trustlist - List trusted players</string>
    <string name="server_land_cmd_7">/land ban &lt;player&gt; - Ban a Player from your land</string>
